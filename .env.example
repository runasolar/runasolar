# Telegram bot for lead notifications.
# Get token from @BotFather, chat ID from @userinfobot (personal) or @RawDataBot (group).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX) from analytics.google.com
NEXT_PUBLIC_GA_ID=

# Canonical site URL (no trailing slash). Used by sitemap, robots, JSON-LD, OG, canonical link.
NEXT_PUBLIC_SITE_URL=https://runasolar.in.ua

# Resend — client confirmation emails. Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender. While the domain isn't verified in Resend, use the sandbox sender
# (works only for the email that owns the Resend account).
RESEND_FROM=RUNA SOLAR <onboarding@resend.dev>
